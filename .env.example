# Copy to .env and fill in your MySQL password.
# Django uses these for DB connection (see gym_accounting/settings.py).

DB_NAME=gym_accounting
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# ML: minimum confidence (0–1) to assign a label when uploading CSV. Below this, leave label blank.
# ML_AUTO_LABEL_MIN_CONFIDENCE=0.5

# Optional for production:
# DJANGO_SECRET_KEY=your-secret-key
# DEBUG=False
